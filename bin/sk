#!/usr/bin/env bash
# sk — SecureKeys CLI
# Manage encrypted API keys/secrets Login Credebtials stored in an AES-256 vault
#
# An IMportant AddOn? Not allowing a user to add already matching key_name, also allow users to edit credentials just in case they change their password
#
#
# Usage:
#   sk init                    Create a new encrypted vault
#   sk add <NAME> [value]      Add or update a secret
#   sk get <NAME>              Print a single secret (decrypted)
#   sk list                    List all secret names (no values shown)
#   sk remove <NAME>           Delete a secret from the vault
#   sk export                  Print all secrets as export statements
#   sk shell-init              Print the path to the env-loader (for .zshrc)
#   sk load                    Load all secrets into current shell session
#   sk rotate                  Re-encrypt the vault with a new master password
#   sk destroy                 Permanently delete the vault
#   sk status                  Show vault info

# SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_DIR=~/.local/lib/securekeys/crypto.sh
INSTALL_DIR="${INSTALL_DIR:-$HOME/.local/bin}" 
LIB_DIR="$HOME/.local/lib/securekeys" 



if [[ -f "$SCRIPT_DIR" ]]; then
  source "$SCRIPT_DIR"
else
  echo -e "${RED}[ERROR] ${RESET} Could not locate the library responsible for encryption. Check the path ${SCRIPT_DIR}"
  exit 1
fi
#Commands

cmd_init() {
  sk_init_vault
}

cmd_add() {
  local user_value=""
  local pass_value=""
  # local single_value=""
  local name="${1:-}"
  # local value="${2:-}"

  [[ -z "$name" ]] && {
    echo -e "${RED}[ERROR]${RESET} Usage: sk add <NAME> " >&2 # [Value] was removed here, to ensure i do not paste key on terminal?
    return 1
  }

  # Validate key name
  if [[ ! "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    echo -e "${RED}[ERROR]${RESET} Key name must be a valid shell variable (letters, digits, underscores)." >&2
    return 1
  fi
  # Newer Support: LogIn Keys embedding
  printf "${BOLD}Are you trying to add Login-In Credentials (requires username + Password) [y/N]:${RESET}"
  read -r is_login

  if [[ "$is_login" =~ [yY]$ ]]; then
    printf "${BOLD}Enter Username: ${RESET}"
    read -r user_value
    printf "${BOLD}Enter the password:${RESET} "
    read -rs pass_value
    printf "\n" >&2
  else
    # Now, Going to rely on Prompting for value. Value should not be parsed with the add argument.
    printf "${BOLD}Value for %s: ${RESET}" "$name" >&2
    read -rs value
    printf "\n" >&2
  fi

  local password
  password=$(_sk_prompt_password "Master password: ")

  local vault_json
  vault_json=$(_sk_read_vault "$password") || return 1

  local updated="$vault_json"
  # updated=$(_json_set "$vault_json" "$name" "$value")

  if [[ "$is_login" =~ [yY]$ ]]; then
    updated=$(_json_set "$updated" "${name}_USER" "$user_value")
    updated=$(_json_set "$updated" "${name}_PASS" "$pass_value")
    _sk_write_vault "$password" "$updated"
    echo -e "${GREEN} [OK]${RESET} Login Details Saved"
  else
    updated=$(_json_set "$updated" "${name}" "$value")
    _sk_write_vault "$password" "$updated"
    echo -e "${GREEN} [OK]${RESET} Key Details Saved"
  fi
  # Remove the value in memory once saved
  unset updated password pass_value user_value
}


cmd_edit() {
  local name="${1:-}"

  [[ -z "$name" ]] && {
    echo -e "${RED}[ERROR]${RESET} Usage: sk edit <NAME>" >&2
    return 1
  }

  local password
  password=$(_sk_prompt_password "Master password: ")

  local vault_json
  vault_json=$(_sk_read_vault "$password") || return 1

  local existing_user
  local existing_pass
  local existing_value

  existing_user=$(_json_get "$vault_json" "${name}_USER")
  existing_pass=$(_json_get "$vault_json" "${name}_PASS")
  existing_value=$(_json_get "$vault_json" "$name")

  # check key exists
  if [[ -z "$existing_user" && -z "$existing_pass" && -z "$existing_value" ]]; then
    echo -e "${RED}[ERROR]${RESET} Key '${name}' not found." >&2
    return 1
  fi

  local updated="$vault_json"

  # Login creds
  if [[ -n "$existing_user" || -n "$existing_pass" ]]; then
    echo -e "${CYAN}[INFO]${RESET} Editing login credentials for '${BOLD}${name}${RESET}'"

    local new_user
    local new_pass

    printf "${BOLD}New Username${DIM} (leave blank to keep current)${RESET}: "
    read -r new_user

    printf "${BOLD}New Password${DIM} (leave blank to keep current)${RESET}: "
    read -rs new_pass
    printf "\n"

    [[ -z "$new_user" ]] && new_user="$existing_user"
    [[ -z "$new_pass" ]] && new_pass="$existing_pass"

    updated=$(_json_set "$updated" "${name}_USER" "$new_user") || {
      echo -e "${RED}[ERROR]${RESET} Failed updating username."
      return 1
    }

    updated=$(_json_set "$updated" "${name}_PASS" "$new_pass") || {
      echo -e "${RED}[ERROR]${RESET} Failed updating password."
      return 1
    }

    _sk_write_vault "$password" "$updated" || {
      echo -e "${RED}[ERROR]${RESET} Failed writing vault."
      return 1
    }

    echo -e "${GREEN}[OK]${RESET} Login credentials updated."

  else
    echo -e "${CYAN}[INFO]${RESET} Editing secret '${BOLD}${name}${RESET}'"

    local new_value

    printf "${BOLD}Enter new value:${RESET} "
    read -rs new_value
    printf "\n"

    [[ -z "$new_value" ]] && {
      echo -e "${RED}[ERROR]${RESET} Secret cannot be empty."
      return 1
    }

    updated=$(_json_set "$updated" "$name" "$new_value") || {
      echo -e "${RED}[ERROR]${RESET} Failed updating secret."
      return 1
    }

    _sk_write_vault "$password" "$updated" || {
      echo -e "${RED}[ERROR]${RESET} Failed writing vault."
      return 1
    }

    echo -e "${GREEN}[OK]${RESET} Secret updated."
  fi

  unset \
    password \
    vault_json \
    updated \
    existing_user \
    existing_pass \
    existing_value \
    new_user \
    new_pass \
    new_value
}



_sk_copy() {
  local input="$1"
  local clear_delay=15 # Seconds before clipboard clears automatically 

  # 1. Wayland (nEED TO BE TESTED. STRAIGHT FROM DOCS) : https://man.archlinux.org/man/wl-copy.1
  if [[ -n "$WAYLAND_DISPLAY" ]] && command -v wl-copy >/dev/null 2>&1; then
    # --paste-once: Serve the selection to only one requester and then exit
    echo -n "$input" | wl-copy --paste-once && return 0

  # 2. macOS
  elif command -v pbcopy >/dev/null 2>&1; then
    echo -n "$input" | pbcopy
    # Background a task to clear the clipboard after delay ste above!
    (sleep "$clear_delay" && printf "" | pbcopy) >/dev/null 2>&1 &
    return 0

  # 3. Fedora
  elif command -v xclip >/dev/null 2>&1; then
    echo -n "$input" | xclip -selection clipboard 
    (sleep "$clear_delay" && echo -n "" | xclip -selection clipboard) >/dev/null 2>&1 &
    return 0

    # 4. WSL (Windows ) Not tested at all, Check out: https://superuser.com/questions/1618537/use-clipboard-through-wsl
  elif command -v clip.exe >/dev/null 2>&1; then
    echo -n "$input" | clip.exe
    (sleep "$clear_delay" && echo -n "" | clip.exe) >/dev/null 2>&1 &
    return 0
  fi

  return 1
}
cmd_get() {
  local name="${1:-}"
  local user_name
  local pass_value
  [[ -z "$name" ]] && {
    printf "${RED}[ERROR]${RESET} Usage: sk get <NAME>\n" >&2
    return 1
  }

  local password
  password=$(_sk_prompt_password "Master password: ")
  local vault_json
  vault_json=$(_sk_read_vault "$password") || return 1
  pass_value=$(_json_get "$vault_json" "${name}_PASS")
  user_name=$(_json_get "$vault_json" "${name}_USER")
  # If the field returned has the Password and Username? Then it has to be log in creds
  if [[ -n "$user_name" && -n "$pass_value" ]]; then
    echo -e "${CYAN} [Logins]${RESET} Username: ${BOLD} ${user_name} ${RESET}\n"
    if _sk_copy "$pass_value"; then
      echo -e "${GREEN} [OK] ${RESET} Password is copied to the clipboard"
      echo -e "${BOLD} [WARN] ${RESET} The Copied Password will disappear in 15 seconds for safety reasons"
    else
      echo -e "${RED}[ERROR]${RESET} No Clipboard was found to copy your password!"
      unset user_name pass_value password vault_json
      return 1
    fi
    unset user_name pass_value password vault_json
    return 0
  fi
  # NOw check , jsut in case this is just a plain secret insteasd of login creds
  local value
  value=$(_json_get "$vault_json" "$name")

  if [[ -z "$value" ]]; then
    echo -e "${RED}[ERROR]${RESET} Key '${name}' not found.\n"
    return 1
  fi

  if _sk_copy "$value"; then
    printf "${GREEN}[OK]${RESET} Secret for '${BOLD}%s${RESET}' copied to clipboard.\n" "$name"

    if [[ -n "$WAYLAND_DISPLAY" ]]; then
      printf "${DIM}Clipboard will clear after the first paste.${RESET}\n"
    else
      printf "${DIM}Clipboard will clear automatically in 15 seconds.${RESET}\n"
    fi
  else
    printf "${RED}[ERROR]${RESET} No clipboard tool found.\n" >&2
    unset value password
    return 1
  fi
  unset value password vault_json
}
 cmd_list() {
  local password
  password=$(_sk_prompt_password "Master password: ")

  local vault_json
  vault_json=$(_sk_read_vault "$password") || return 1

  local keys=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && keys+=("$line")
  done < <(_json_keys "$vault_json")

  if [[ ${#keys[@]} -eq 0 || (${#keys[@]} -eq 1 && -z "${keys[0]}") ]]; then
    echo -e "${DIM}Vault is empty. Add a secret with: ${BOLD}sk add MY_API_NAME ${RESET}"
    return
  fi

  local visible_count=0
  for key in "${keys[@]}"; do
    [[ -z "$key" ]] && continue
    [[ "$key" =~ _PASS$ ]] && continue
    ((visible_count++))
  done

  echo -e "\n${BOLD}${CYAN}Stored Credentials${RESET} ${DIM}(${visible_count} total)${RESET}\n"
  local masked="••••••••••••"
  for key in "${keys[@]}"; do
    [[ -z "$key" ]] && continue

    if [[ "$key" =~ _PASS$ ]]; then
      continue
    elif [[ "$key" =~ _USER$ ]]; then
      #Formatting ?
      local base_key="${key%_USER}"
      echo -e " ${GREEN}${RESET} $base_key : ${DIM}[Login Details]${RESET}"
    else
      echo -e " ${GREEN}${RESET} $key : ${DIM}$masked${RESET}"
    fi
  done
  unset password vault_json keys
}
cmd_remove() {
  local name="${1:-}"
  [[ -z "$name" ]] && {
    echo -e "${RED}[ERROR]${RESET} Usage: sk remove <NAME>" >&2
    return 1
  }

  local password
  password=$(_sk_prompt_password "Master password: ")

  local vault_json
  vault_json=$(_sk_read_vault "$password") || return 1

  local has_single=false
  local has_login=false

  # Now check for the standard key - api pair
  local value
  value=$(_json_get "$vault_json" "$name")
  [[ -n "$value" ]] && has_single=true

  local user_val
  user_val=$(_json_get "$vault_json" "${name}_USER")
  [[ -n "$user_val" ]] && has_login=true

  if ! $has_single && ! $has_login; then
    echo -e "${RED}[ERROR]${RESET} Key '$name' not found." >&2
    return 1
  fi

  printf "${YELLOW}[WARN]${RESET} Remove '${BOLD}%s${RESET}'? [y/N] " "$name"
  read -r confirm
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && {
    echo "Aborted."
    return
  }

  local updated="$vault_json"
  if $has_single; then
    updated=$(_json_delete "$updated" "$name")
  fi
  if $has_login; then
    updated=$(_json_delete "$updated" "${name}_USER")
    updated=$(_json_delete "$updated" "${name}_PASS")
  fi

  _sk_write_vault "$password" "$updated"
  echo -e "${GREEN}[OK]${RESET} '$name' removed."
  unset password vault_json updated
}

cmd_export() {
  local password
  password=$(_sk_prompt_password "Master password: ")

  local vault_json
  vault_json=$(_sk_read_vault "$password") || return 1

  local keys
  # mapfile -t keys < <(_json_keys "$vault_json")
  while IFS= read -r line; do
    [[ -n "$line" ]] && keys+=("$line")
  done < <(_json_keys "$vault_json")

  for key in "${keys[@]}"; do
    [[ -z "$key" ]] && continue
    local value
    value=$(_json_get "$vault_json" "$key")
    printf 'export %s="%s"\n' "$key" "$value"
  done
  unset password vault_json value
}

cmd_load() {
  # TODO This is really not important, Currently could allow interception? so will have it hanging for now
  # This must be sourced to take effect in the current shell.
  # We print export statements for eval.
  local password
  password=$(_sk_prompt_password "Master password (loading vault into session): ")

  local vault_json
  vault_json=$(_sk_read_vault "$password") || return 1

  local keys
  # mapfile -t keys < <(_json_keys "$vault_json")
  while IFS= read -r line; do
    [[ -n "$line" ]] && keys+=("$line")
  done < <(_json_keys "$vault_json")
  local count=0

  for key in "${keys[@]}"; do
    [[ -z "$key" ]] && continue
    local value
    value=$(_json_get "$vault_json" "$key")
    export "$key=$value"
    ((count++))
  done

  echo -e "${GREEN}[OK]${RESET} Loaded ${BOLD}$count${RESET} secret(s) into session." >&2
}

cmd_shell_init() {
  # Returns the path to the shell integration file so users can:
  #   source $(sk shell-init)
  # Or adds an sk-load function to their shell.
  local init_script="$SECUREKEYS_DIR/shell-init.sh"
  mkdir -p "$SECUREKEYS_DIR"
  cat <<EOF >"$init_script"
  # sk integration
  # sk integration
  # Provides: sk-load  — interactively loads all vault secrets into current session
  sk-load() {
    local sk_bin
    sk_bin="$(command -v sk 2>/dev/null || echo "$HOME/.securekeys/bin/sk")"
    eval \$("\$sk_bin" export)
    echo "Secrets loaded into session." >&2
  }
EOF

  chmod 600 "$init_script"
  echo "$init_script"
}

cmd_rotate() {
  echo -e "${BOLD}${CYAN}Rotate Master Password${RESET}\n"

  local old_password
  old_password=$(_sk_prompt_password "Current master password: ")

  local vault_json
  vault_json=$(_sk_read_vault "$old_password") || return 1

  local new_password
  new_password=$(_sk_prompt_password "New master password: ")
  local confirm
  confirm=$(_sk_prompt_password "Confirm new password: ")

  if [[ "$new_password" != "$confirm" ]]; then
    echo -e "\n${RED}[ERROR]${RESET} Passwords do not match. Password NOT changed."
    return 1
  fi

  # Re-generate salt for extra security
  openssl rand -hex 32 >"$SALT_FILE"
  _sk_write_vault "$new_password" "$vault_json"

  echo -e "\n${GREEN}[OK]${RESET} Master password rotated and vault re-encrypted with new salt."
}

cmd_destroy() {
  echo -e "${RED}${BOLD}WARNING: This will permanently delete your entire vault.${RESET}"
  echo -e "Type ${BOLD}DELETE${RESET} to confirm: "
  read -r confirm
  if [[ "$confirm" == "DELETE" ]]; then
    rm -rf "$SECUREKEYS_DIR"
    echo -e "${GREEN}[OK]${RESET} Vault destroyed."
  else
    echo "Aborted."
  fi
}

cmd_status() {
  echo -e "\n${BOLD}${CYAN}SecureKeys Vault Status${RESET}\n"
  if [[ ! -d "$SECUREKEYS_DIR" ]]; then
    echo -e "  ${RED}No vault found.${RESET} Run: ${CYAN}sk init${RESET}\n"
    return
  fi

  local vault_size="N/A"
  [[ -f "$VAULT_FILE" ]] && vault_size=$(du -sh "$VAULT_FILE" 2>/dev/null | cut -f1)

  local perms
  if stat -c '%a' . >/dev/null 2>&1; then
    perms=$(stat -c '%a' "$SECUREKEYS_DIR")
  else
    perms=$(stat -f '%Lp' "$SECUREKEYS_DIR")
  fi

  # local created="Unknown"
  # if [[ -f "$META_FILE" ]]; then
  #   created=$(grep -oP '"created"\s*:\s*"\K[^"]+' "$META_FILE" 2>/dev/null || echo "Unknown")
  # fi

  echo -e "  ${DIM}Vault path   :${RESET}  $SECUREKEYS_DIR"
  echo -e "  ${DIM}Vault file   :${RESET}  $VAULT_FILE"
  echo -e "  ${DIM}Vault size   :${RESET}  $vault_size"
  # echo -e "  ${DIM}Created      :${RESET}  $created"
  echo -e "  ${DIM}Algorithm    :${RESET}  AES-256-CBC + PBKDF2 (100,000 iterations, SHA-256)"
  echo -e "  ${DIM}Permissions  :${RESET}  $perms"
  echo
}
cmd_uninstall() {
  local bin_removed=false
  local lib_removed=false

  echo -e "\n${BOLD}${CYAN}Removing the tool and its supporting Libraries...${RESET}\n"

  # Remove the sk binary stored in the bin folde
  if [[ -f "$INSTALL_DIR/sk" ]]; then
    rm -f "$INSTALL_DIR/sk"
    echo -e "${GREEN}[OK]${RESET} Removed ${CYAN}$INSTALL_DIR/sk${RESET}"
    bin_removed=true
  else
    echo -e "${RED}[WARN]${RESET} ${CYAN}$INSTALL_DIR/sk${RESET} not found"
  fi

  # Remove the library directory containing crypto.sh
  if [[ -d "$LIB_DIR" ]]; then
    rm -rf "$LIB_DIR"
    echo -e "${GREEN}[OK]${RESET} Removed library directory ${CYAN}$LIB_DIR${RESET}"
    lib_removed=true
  else
    echo -e "${RED}[WARN]${RESET} Library directory ${CYAN}$LIB_DIR${RESET} not found"
  fi

  # if [[ -d "$HOME/.local/lib" ]] && [[ -z "$(ls -A "$HOME/.local/lib" 2>/dev/null)" ]]; then
  #   rmdir "$HOME/.local/lib"
  #   echo -e "${GREEN}[OK]${RESET} Removed empty directory ${CYAN}$HOME/.local/lib${RESET}"
  # fi
  #
  if [[ "$bin_removed" == "true" && "$lib_removed" == "true" ]]; then
    echo -e "\n${GREEN}[OK]${RESET} sk uninstalled successfully."
  else
    echo -e "\n${YELLOW}[WARN]${RESET} Verification needed: Please check if binary or libraries still exist."
  fi
  echo -e "${CYAN}Remember to remove any PATH exports or integrations from your shell profile (.zshrc / .bashrc)${RESET}\n"
}

cmd_help() {
  # Removed Lines,:
  # ${GREEN}sk shell-init${RESET}     Print path to shell integration file
  # ${GREEN}sk export${RESET}         Print all secrets as shell export statements
  # ${GREEN}sk load${RESET}           Load all secrets into current shell session
  #
  echo -e "
${BOLD}${CYAN}sk${RESET} SecureKeys CLI Tool ${DIM}${RESET}

${BOLD}${UNDERLINE}COMMANDS${RESET}
  ${GREEN}sk init${RESET}           Create a new encrypted vault
  ${GREEN}sk add${RESET} ${DIM}NAME${RESET}      Add or update a secret
  ${GREEN}sk get${RESET} ${DIM}NAME${RESET}      Decrypt and print a single secret
  ${GREEN}sk list${RESET}           List all secret names (values masked)
  ${GREEN}sk edit${RESET} ${DIM}NAME${RESET}     Edit an existing secret or login
  ${GREEN}sk remove | rm ${RESET} ${DIM}NAME${RESET}   Delete a secret from the vault
  ${GREEN}sk rotate${RESET}         Change master password (re-encrypts vault)
  ${GREEN}sk destroy${RESET}        ${YELLOW}a${RESET} Permanently delete the vault
  ${GREEN}sk status${RESET}         Show vault info
  ${GREEN}sk uninstall${RESET}      Safely remove the sk executable and library files

${BOLD}${UNDERLINE}EXAMPLES${RESET}
  sk add OPENAI_API_NAME  - ${BOLD}You Only enter the name of the key, Not the actual Key${RESET}
  sk get gh_token
  sk status
  sk remove gh_token
  
  ${BOLD}${UNDERLINE}SECURITY${RESET}
  - ${BOLD}AES-256-CBC${RESET} encryption via OpenSSL
  - ${BOLD}PBKDF2${RESET} key derivation
  - Master password is ${BOLD}never stored${RESET} on disk
  - Vault permissions restricted to current user 
"
}
# Dispatch
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
  init) cmd_init "$@" ;;
  add) cmd_add "$@" ;;
  get) cmd_get "$@" ;;
  list) cmd_list "$@" ;;
  edit) cmd_edit "$@" ;;
  remove | rm) cmd_remove "$@" ;;
  # export) cmd_export "$@" ;;
  # load) cmd_load "$@" ;;
  # shell-init) cmd_shell_init "$@" ;;
  rotate) cmd_rotate "$@" ;;
  destroy) cmd_destroy "$@" ;;
  status) cmd_status "$@" ;;
  uninstall) cmd_uninstall "$@";;
  help | --help | -h) cmd_help ;;
  *)
    echo -e "${RED}[ERROR]${RESET} Unknown command: $cmd" >&2
    cmd_help
    return 1
    ;;
  esac
}

main "$@"
